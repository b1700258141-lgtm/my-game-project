    "commission_ring_quest": {
      "speaker": "看上去有点腼腆的年轻人",
      "portrait": "portrait_ring_boy",
      "lines": [
        {
          "id": "r3",
          "text": "我最近在家里翻出一枚祖传的戒指，看上去有点老了，家里人也说不清楚来历，能不能帮我调查一下...我，我会付给你报酬的！"
        }
      ],
      "choices": [
        {
          "text": "当然，我就是干这个的。",
          "effects": {},
          "next": "commission_ring_end"
        }
      ]
    },
    "commission_ring_after": {
