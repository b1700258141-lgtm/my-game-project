    "commission_digestive_reason": {
      "speaker": "肚子很大的厨师",
      "portrait": "portrait_chef_digestive",
      "lines": [
        {
          "id": "d2",
          "text": "听说你这里能制作出神奇的药品，我想委托你帮我制作出让肠胃快速消化的消食片..."
        }
      ],
      "choices": [
        {
          "text": "能冒昧问一下缘由吗？",
          "effects": {},
          "next": "commission_digestive_detail"
        }
      ]
    },
    "commission_digestive_detail": {
      "speaker": "肚子很大的厨师",
      "portrait": "portrait_chef_digestive",
      "lines": [
        {
          "id": "d3",
          "text": "（有点尴尬地挠了挠头），不瞒你说，因为我在后厨经常要试吃菜品，久而久之，总感觉肚子涨涨的... 去医院做过检查也没有实际解决，所以才来这里找你"
        }
      ],
      "choices": [
        {
          "text": "哈哈，这样啊。乐意效劳。",
          "effects": {
            "flags": { "digestive_commission_accepted": true }
          },
          "next": null
        }
      ]
    },
    "commission_ring_start": {
      "speaker": "看上去有点腼腆的年轻人",
      "portrait": "portrait_ring_boy",
      "lines": [
        {
          "id": "r1",
          "text": "请..请问这里是新开的万事屋吗？我想委托你一件事情"
        }
      ],
      "choices": [
        {
          "text": "请说吧",
          "effects": {},
          "next": "commission_ring_quest"
        }
      ]
