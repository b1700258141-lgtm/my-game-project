    "commission_convenience_store_start": {
      "speaker": "顶着黑眼圈的便利店员",
      "portrait": "portrait_convenience_clerk",
      "lines": [
        { "id": "cs1", "text": "你就是这家万事屋的老板吗？太好了，我刚好想找人帮忙。" }
      ],
      "choices": [
        { "text": "发生什么事了？", "effects": {}, "next": "commission_convenience_store_problem" }
      ]
    },
    "commission_convenience_store_problem": {
      "speaker": "顶着黑眼圈的便利店员",
      "portrait": "portrait_convenience_clerk",
      "lines": [
