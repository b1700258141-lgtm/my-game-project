{
  "dialogues": {
    "visitor_teacher_intro": {
      "speaker": "退休教师",
      "portrait": "portrait_teacher",
      "lines": [
        {
          "id": "t1",
          "text": "你好，请问这里是万事屋吗？我在学校退休后，常听学生家长提起这家店。"
        },
        {
          "id": "t2",
          "text": "我有几份旧教案和一枚旧铜钱，总觉得和这间店有点说不清的缘分。"
        }
      ],
      "choices": [
        {
          "text": "请进，请坐",
          "effects": {
            "npcAffinity": { "visitor_teacher": 5 }
          },
          "next": "visitor_teacher_talk"
        },
        {
          "text": "我们确实能帮上忙",
          "effects": {
            "popularity": 1
          },
          "next": "visitor_teacher_talk"
        }
      ]
    },
    "visitor_teacher_talk": {
      "speaker": "退休教师",
      "portrait": "portrait_teacher",
      "lines": [
        {
          "id": "t3",
          "text": "这些东西是我整理老办公室时翻出来的。旧铜钱你先留着，也许比放在我抽屉里更有用。"
        },
        {
          "id": "t4",
          "text": "至于那张油印纸条，我想先看看你是不是真的愿意听老故事。"
        }
      ],
      "choices": [
        {
          "text": "我愿意听您慢慢说",
          "effects": {
            "addItem": "material_old_coin",
            "npcAffinity": { "visitor_teacher": 10 },
            "flags": { "received_gift_from_teacher": true }
          },
          "next": "visitor_teacher_gift"
        },
        {
          "text": "欢迎随时再来",
          "effects": {
            "flags": { "teacher_visited": true }
          },
          "next": null
        }
      ]
    },
    "visitor_teacher_gift": {
      "speaker": "退休教师",
      "portrait": "portrait_teacher",
      "lines": [
        {
          "id": "tg1",
          "text": "你愿意认真听，我就放心了。现在肯这样听人把话说完的年轻人不多。"
        },
        {
          "id": "tg2",
          "text": "这张油印纸条夹在教案里，上面的店名被墨水晕开了，只剩一个像门牌的图案。"
        }
      ],
      "choices": [
        {
          "text": "这是什么？",
          "effects": {
            "addKeyItem": "key_item_004",
            "flags": { "teacher_trust_established": true }
          },
          "next": "visitor_teacher_bye"
        }
      ]
    },
    "visitor_teacher_bye": {
      "speaker": "退休教师",
      "portrait": "portrait_teacher",
      "lines": [
        {
          "id": "tbye1",
          "text": "那我先回去了。以后要是店里需要整理档案，记得叫我，我最会给旧纸张编号。"
        }
      ],
      "choices": [
        {
          "text": "谢谢，慢走",
          "effects": {
            "flags": { "teacher_first_talk_done": true }
          },
          "next": null
        }
      ]
    },
    "visitor_chef_intro": {
      "speaker": "饭馆厨师",
      "portrait": "portrait_chef",
      "lines": [
        {
          "id": "chef1",
          "text": "打扰了，这里是万事屋吧？我从街角饭馆过来的。"
        },
        {
          "id": "chef2",
          "text": "后厨最近翻出一本老菜谱，纸页一打开就有股很淡的铜锈味，我想请你看看。"
        }
      ],
      "choices": [
        {
          "text": "请说，什么事？",
          "effects": {
            "npcAffinity": { "visitor_chef": 5 }
          },
          "next": "visitor_chef_talk"
        },
        {
          "text": "请坐，慢慢说",
          "effects": {
            "popularity": 1
          },
          "next": "visitor_chef_talk"
        }
      ]
    },
    "visitor_chef_talk": {
      "speaker": "饭馆厨师",
      "portrait": "portrait_chef",
      "lines": [
        {
          "id": "chef3",
          "text": "我们店最近想把几道老菜重新做起来，味道不能只靠调料，得把那点旧规矩也找回来。"
        },
        {
          "id": "chef4",
          "text": "听说你们万事屋对旧物和炼金都有点门道，我就厚着脸皮来了。"
        },
        {
          "id": "chef4b",
          "text": "对了，今天后厨多备了些萝卜和风铃草，能换就换，不能换也当交个朋友。"
        }
      ],
      "choices": [
        {
          "text": "有什么我可以帮忙的吗？",
          "effects": {
            "npcAffinity": { "visitor_chef": 5 }
          },
          "next": "visitor_chef_commission"
        },
        {
          "text": "看看你带来了什么",
          "effects": {
            "flags": { "chef_visited": true }
          },
          "next": "visitor_chef_items"
        },
        {
          "text": "感兴趣，请详细说说",
          "effects": {
            "flags": { "chef_visited": true }
          },
          "next": "visitor_chef_bye"
        }
      ]
    },
    "visitor_chef_items": {
      "speaker": "饭馆厨师",
      "portrait": "portrait_chef",
      "lines": [
        {
          "id": "ci1",
          "text": "这两根萝卜是早市刚送来的，20资金拿走吧。厨房里少两根也不影响开火。"
        }
      ],
      "choices": [
        {
          "text": "买下萝卜（-20资金）",
          "effects": {
            "funds": -20,
            "addItem": "material_carrot"
          },
          "next": "visitor_chef_bye"
        },
        {
          "text": "太贵了，下次再说",
          "effects": {},
          "next": "visitor_chef_bye"
        }
      ]
    },
    "visitor_chef_commission": {
      "speaker": "饭馆厨师",
      "portrait": "portrait_chef",
      "lines": [
        {
          "id": "cc1",
          "text": "说起来，我确实有个小请求。那本老菜谱的封皮里，夹着一块不像装饰的铜纹碎片。"
        },
        {
          "id": "cc2",
          "text": "你要是愿意帮我确认它是不是万事屋的东西，我就把碎片交给你保管。"
        }
      ],
      "choices": [
        {
          "text": "先把碎片交给我，我会登记清楚",
          "effects": {
            "addKeyItem": "key_item_001",
            "npcAffinity": { "visitor_chef": 10 }
          },
          "next": "visitor_chef_bye"
        },
        {
          "text": "我考虑一下",
          "effects": {},
          "next": "visitor_chef_bye"
        }
      ]
    },
    "visitor_chef_bye": {
      "speaker": "饭馆厨师",
      "portrait": "portrait_chef",
      "lines": [
        {
          "id": "chef5",
          "text": "那我先回后厨了。锅上还炖着汤，离开太久师傅们会把咸淡全推给我。"
        }
      ],
      "choices": [
        {
          "text": "好的，再见",
          "effects": {
            "flags": { "chef_first_talk_done": true }
          },
          "next": null
        }
      ]
    },
    "visitor_courier_intro": {
      "speaker": "快递员",
      "portrait": "portrait_courier",
      "lines": [
        {
          "id": "cou1",
          "text": "你好，有你们的快递！门牌挺旧，但地址写得很清楚。"
        },
        {
          "id": "cou2",
          "text": "万事屋？我每天跑这片，倒是第一次见有人真把这三个字挂出来。"
        }
      ],
      "choices": [
        {
          "text": "谢谢，慢走",
          "effects": {
            "popularity": 1
          },
          "next": "visitor_courier_talk"
        },
        {
          "text": "进来坐坐？",
          "effects": {
            "npcAffinity": { "visitor_courier": 5 }
          },
          "next": "visitor_courier_talk"
        }
      ]
    },
    "visitor_courier_talk": {
      "speaker": "快递员",
      "portrait": "portrait_courier",
      "lines": [
        {
          "id": "cou3",
          "text": "不了不了，还要赶着送下一单。只是刚才路过巷口，看到墙根有几株狗尾巴草长得挺精神。"
        },
        {
          "id": "cou4",
          "text": "你要是不嫌弃，我顺手摘了两株。跑腿的人没什么贵重东西，能带点路上的消息。"
        }
      ],
      "choices": [
        {
          "text": "有空常来",
          "effects": {
            "addItem": "material_foxtail_grass",
            "flags": { "courier_visited": true }
          },
          "next": null
        }
      ]
    },
    "visitor_antique_intro": {
      "speaker": "古玩店老板",
      "portrait": "portrait_antique",
      "lines": [
        {
          "id": "ant1",
          "text": "打扰了，请问你们这里收不收老物件？我在古玩街开店，多少见过些门道。"
        },
        {
          "id": "ant2",
          "text": "万事屋重新开门，街坊都在猜。我来不是探底，只是想看看能不能互通有无。"
        }
      ],
      "choices": [
        {
          "text": "请进来详谈",
          "effects": {
            "npcAffinity": { "visitor_antique": 5 }
          },
          "next": "visitor_antique_talk"
        },
        {
          "text": "我们主要是帮人处理事情",
          "effects": {
            "flags": { "antique_explained": true }
          },
          "next": "visitor_antique_talk"
        }
      ]
    },
    "visitor_antique_talk": {
      "speaker": "古玩店老板",
      "portrait": "portrait_antique",
      "lines": [
        {
          "id": "ant3",
          "text": "处理事情？这说法比收货有意思。旧物麻烦多，很多麻烦不在价钱上。"
        },
        {
          "id": "ant4",
          "text": "我这里有些旧铜钱和甲壳虫标本，也有几件说不清来路的小东西。"
        }
      ],
      "choices": [
        {
          "text": "有什么特别的？",
          "effects": {
            "npcAffinity": { "visitor_antique": 5 }
          },
          "next": "visitor_antique_trade"
        },
        {
          "text": "我有东西想交换",
          "effects": {
            "flags": { "antique_trade_interest": true }
          },
          "next": "visitor_antique_exchange"
        },
        {
          "text": "好的，再见",
          "effects": {
            "flags": { "antique_visited": true }
          },
          "next": null
        }
      ]
    },
    "visitor_antique_trade": {
      "speaker": "古玩店老板",
      "portrait": "portrait_antique",
      "lines": [
        {
          "id": "at1",
          "text": "旧铜钱20资金，甲壳虫10资金。都是干净来源，账本可以给你看。"
        }
      ],
      "choices": [
        {
          "text": "买旧铜钱（-20资金）",
          "effects": {
            "funds": -20,
            "addItem": "material_old_coin"
          },
          "next": "visitor_antique_trade2"
        },
        {
          "text": "买甲壳虫（-10资金）",
          "effects": {
            "funds": -10,
            "addItem": "material_beetle"
          },
          "next": "visitor_antique_trade2"
        },
        {
          "text": "下次再说",
          "effects": {},
          "next": "visitor_antique_bye"
        }
      ]
    },
    "visitor_antique_trade2": {
      "speaker": "古玩店老板",
      "portrait": "portrait_antique",
      "lines": [
        {
          "id": "at2",
          "text": "还要别的吗？旧物讲眼缘，素材也一样。"
        }
      ],
      "choices": [
        {
          "text": "买旧铜钱（-20资金）",
          "effects": {
            "funds": -20,
            "addItem": "material_old_coin"
          },
          "next": "visitor_antique_trade2"
        },
        {
          "text": "买甲壳虫（-10资金）",
          "effects": {
            "funds": -10,
            "addItem": "material_beetle"
          },
          "next": "visitor_antique_trade2"
        },
        {
          "text": "够了，谢谢",
          "effects": {},
          "next": "visitor_antique_bye"
        }
      ]
    },
    "visitor_antique_exchange": {
      "speaker": "古玩店老板",
      "portrait": "portrait_antique",
      "lines": [
        {
          "id": "ae1",
          "text": "交换？让我想想。你这店刚开，最缺的可能不是货，而是能对上的线索。"
        },
        {
          "id": "ae2",
          "text": "我有一枚药签形状的纹章片，压在旧账本里多年。你若愿意替我记清它的来处，就带走吧。"
        }
      ],
      "choices": [
        {
          "text": "收下纹章片，并承诺登记来源",
          "effects": {
            "addKeyItem": "key_item_002",
            "npcAffinity": { "visitor_antique": 15 },
            "flags": { "antique_trade_done": true }
          },
          "next": "visitor_antique_bye"
        },
        {
          "text": "我暂时不收来路不明的东西",
          "effects": {},
          "next": "visitor_antique_bye"
        }
      ]
    },
    "visitor_antique_bye": {
      "speaker": "古玩店老板",
      "portrait": "portrait_antique",
      "lines": [
        {
          "id": "ab1",
          "text": "好的，以后有能说清来路的好东西，我再带来。做旧物生意，最怕账不明。"
        }
      ],
      "choices": [
        {
          "text": "慢走",
          "effects": {
            "flags": { "antique_first_talk_done": true }
          },
          "next": null
        }
      ]
    },
    "commission_digestive_start": {
      "speaker": "肚子很大的厨师",
      "portrait": "portrait_chef_digestive",
      "lines": [
        {
          "id": "d1",
          "text": "你就是万事屋的老板吗？"
        }
      ],
      "choices": [
        {
          "text": "正是在下",
          "effects": {},
          "next": "commission_digestive_reason"
        }
      ]
