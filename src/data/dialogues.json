{
  "dialogues": {
    "visitor_teacher_intro": {
      "speaker": "退休教师",
      "portrait": "portrait_teacher",
      "lines": [
        {
          "id": "t1",
          "text": "【占位】你好，请问这里是万事屋吗？"
        },
        {
          "id": "t2",
          "text": "【占位】我听说你们能帮忙处理一些...特殊的事情？"
        }
      ],
      "choices": [
        {
          "text": "请进，请坐",
          "effects": {
            "npcAffinity": { "visitor_teacher": 5 }
          },
          "next": "visitor_teacher_talk"
        },
        {
          "text": "我们确实能帮上忙",
          "effects": {
            "popularity": 1
          },
          "next": "visitor_teacher_talk"
        }
      ]
    },
    "visitor_teacher_talk": {
      "speaker": "退休教师",
      "portrait": "portrait_teacher",
      "lines": [
        {
          "id": "t3",
          "text": "【占位】我这里有一些老物件，一直想找人帮忙看看..."
        },
        {
          "id": "t4",
          "text": "【占位】不过今天只是先来打个招呼。改天再详细聊聊。"
        }
      ],
      "choices": [
        {
          "text": "这是给您的回礼",
          "effects": {
            "addItem": "material_old_coin",
            "npcAffinity": { "visitor_teacher": 10 },
            "flags": { "received_gift_from_teacher": true }
          },
          "next": "visitor_teacher_gift"
        },
        {
          "text": "欢迎随时再来",
          "effects": {
            "flags": { "teacher_visited": true }
          },
          "next": null
        }
      ]
    },
    "visitor_teacher_gift": {
      "speaker": "退休教师",
      "portrait": "portrait_teacher",
      "lines": [
        {
          "id": "tg1",
          "text": "【占位】这...这是给我的？真是太感谢了。"
        },
        {
          "id": "tg2",
          "text": "【占位】作为回报，这个给你。是我整理旧物时发现的。"
        }
      ],
      "choices": [
        {
          "text": "这是什么？",
          "effects": {
            "addKeyItem": "key_item_001",
            "flags": { "teacher_trust_established": true }
          },
          "next": "visitor_teacher_bye"
        }
      ]
    },
    "visitor_teacher_bye": {
      "speaker": "退休教师",
      "portrait": "portrait_teacher",
      "lines": [
        {
          "id": "tbye1",
          "text": "【占位】那我就先走了。以后有什么需要帮忙的尽管说。"
        }
      ],
      "choices": [
        {
          "text": "谢谢，慢走",
          "effects": {
            "flags": { "teacher_first_talk_done": true }
          },
          "next": null
        }
      ]
    },
    "visitor_chef_intro": {
      "speaker": "饭馆厨师",
      "portrait": "portrait_chef",
      "lines": [
        {
          "id": "chef1",
          "text": "【占位】打扰了，这里是万事屋吧？"
        },
        {
          "id": "chef2",
          "text": "【占位】我是附近饭馆的厨师，有点事情想请教..."
        }
      ],
      "choices": [
        {
          "text": "请说，什么事？",
          "effects": {
            "npcAffinity": { "visitor_chef": 5 }
          },
          "next": "visitor_chef_talk"
        },
        {
          "text": "请坐，慢慢说",
          "effects": {
            "popularity": 1
          },
          "next": "visitor_chef_talk"
        }
      ]
    },
    "visitor_chef_talk": {
      "speaker": "饭馆厨师",
      "portrait": "portrait_chef",
      "lines": [
        {
          "id": "chef3",
          "text": "【占位】我们店最近在整理一些老菜谱，想恢复传统的味道..."
        },
        {
          "id": "chef4",
          "text": "【占位】听说你们对传统的东西比较有研究？"
        },
        {
          "id": "chef4b",
          "text": "【占位】对了，我这里有些东西，也许对你有用。"
        }
      ],
      "choices": [
        {
          "text": "有什么我可以帮忙的吗？",
          "effects": {
            "npcAffinity": { "visitor_chef": 5 }
          },
          "next": "visitor_chef_commission"
        },
        {
          "text": "看看你带来了什么",
          "effects": {
            "flags": { "chef_visited": true }
          },
          "next": "visitor_chef_items"
        },
        {
          "text": "感兴趣，请详细说说",
          "effects": {
            "flags": { "chef_visited": true }
          },
          "next": "visitor_chef_bye"
        }
      ]
    },
    "visitor_chef_items": {
      "speaker": "饭馆厨师",
      "portrait": "portrait_chef",
      "lines": [
        {
          "id": "ci1",
          "text": "【占位】这是一块从旧衣物上剪下的绸缎，50元你拿走？"
