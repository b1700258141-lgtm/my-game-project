      "portrait": "portrait_ring_boy",
      "lines": [
        {
          "id": "ra1",
          "text": "戒指内侧的磨痕很深，像是有人反复用指腹确认它还在。"
        },
        {
          "id": "ra2",
          "text": "所以它不是普通首饰，对吗？我总觉得家里人把它留下，不只是为了纪念。"
        }
      ],
      "choices": [
        {
          "text": "委托我接下了",
