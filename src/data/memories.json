  "dialogues": {
    "ring_memory_dialogue": {
      "speaker": "守城军士精魂",
      "lines": [
        {
          "id": "rm1",
          "text": "军士：「阿砚，别回头。出了东门，一直往南。三十里外有驿站，把这封信交给守备府。」"
        },
        {
          "id": "rm2",
          "text": "同伴：「那你呢？你说过的，等仗打完，要回去给嫂子补一场像样的婚礼。」"
        },
        {
          "id": "rm3",
          "text": "军士把戒指从指间摘下，指节上全是血。他笑了一下，却没敢看城内的灯火：「所以才要你把它带回去。」"
        },
        {
          "id": "rm4",
          "text": "同伴：「我不替你送遗物。你自己送。」"
        },
        {
          "id": "rm5",
          "text": "军士：「这不是遗物。」他把戒指系在红绳上，塞进同伴掌心，「这是我答应过她的事。人可以死，答应过的事不能死。」"
        },
        {
          "id": "rm6",
          "text": "城外鼓声压过夜风。同伴咬着牙，眼眶通红：「你守的是城，还是家？」"
        },
        {
          "id": "rm7",
          "text": "军士抬头看向城墙后密密的屋檐，声音很轻：「城后面就是家。若我退一步，明日哭的就不止她一个人。」"
        },
        {
          "id": "rm8",
          "text": "火光最后一次照亮戒指内侧。那道铜纹像被刀刻进岁月里，留下的不是姓名，而是一句无声的守诺。"
        }
      ],
      "choices": [
        {
          "text": "（结束记忆）",
          "effects": {},
          "next": null
        }
      ]
    },
    "elder_memory_dialogue": {
      "speaker": "教书先生精魂",
      "lines": [
        {
          "id": "em1",
          "text": "学生：「先生，村口的人都走了。娘说再不走，兵就要来了。」"
        },
        {
          "id": "em2",
          "text": "先生把被雨泡皱的书页一张张抚平，指尖沾着墨：「那你怎么还来？」"
        },
        {
          "id": "em3",
          "text": "学生抱紧书袋，声音小得像晨雾：「我怕今日不读，明日就忘了自己叫什么字。」"
        },
        {
          "id": "em4",
          "text": "先生沉默许久，把门栓落下，又把窗推开一线：「那就读。声音小些，腰背直些。」"
        },
        {
          "id": "em5",
          "text": "学生：「先生不逃吗？」"
        },
        {
          "id": "em6",
          "text": "先生笑了笑，替他点亮油灯：「有人守城，有人守药炉。老夫没别的本事，只能替你们守住这几页书。」"
        },
        {
          "id": "em7",
          "text": "屋外马蹄声近了，孩子们的晨读声却一点点齐起来。先生站在门前，像一截瘦竹，风越大，越不肯弯。"
        },
        {
          "id": "em8",
          "text": "后来，教案里夹着的那张旧门牌浮出淡淡纹路。灯芯烧尽前，他写下最后一行：愿后来人仍知归处。"
        }
      ],
      "choices": [
        {
          "text": "（结束记忆）",
          "effects": {},
          "next": null
        }
      ]
    },
    "cat_memory_dialogue": {
      "speaker": "巷中幼童精魂",
      "lines": [
        {
          "id": "cm1",
          "text": "孩子：「小狸——你再不出来，我就真的生气了。」"
        },
        {
          "id": "cm2",
          "text": "邻家阿婆把半碗热汤塞进他手里：「雨这么大，一只猫丢了就丢了，先回家吧。」"
        },
        {
          "id": "cm3",
          "text": "孩子摇头，抱着空竹篮，鞋底全是泥：「它不是丢了就能算了的东西。」"
        },
        {
          "id": "cm4",
          "text": "阿婆：「一只猫而已。」"
        },
        {
          "id": "cm5",
          "text": "孩子低下头，声音发抖：「我病得最厉害那晚，爹娘都去请郎中了。只有它趴在我枕边，一直叫，一直叫……像在喊我别睡。」"
        },
        {
          "id": "cm6",
          "text": "屋檐铜铃被风吹响。阿婆叹了口气，提起灯笼：「那还愣着做什么？我去敲东边的柴门，你沿墙根找。」"
        },
        {
          "id": "cm7",
          "text": "雨巷里，一盏又一盏灯亮了起来。有人递伞，有人喊猫名，窄窄的巷子忽然像一条回家的河。"
        },
        {
          "id": "cm8",
          "text": "檐铃最后轻轻一响。记忆里，小小的爪印停在门槛前，像是在说：被认真牵挂过的生命，总会认得归路。"
        }
      ],
      "choices": [
        {
          "text": "（结束记忆）",
          "effects": {},
          "next": null
        }
      ]
    },
    "photo_memory_dialogue": {
      "speaker": "杏林医者精魂",
      "lines": [
        {
          "id": "pm1",
          "text": "徒弟：「师父，那家人已经欠了三回诊金。您再去，药铺的米缸明日就见底了。」"
        },
        {
          "id": "pm2",
          "text": "医者系紧蓑衣，把最后一包药放进箱中：「米缸见底，还能借。人命见底，拿什么补？」"
        },
        {
          "id": "pm3",
          "text": "徒弟追到门口，雨水顺着屋檐砸下来：「可您也是人，您也会冷，也会饿啊。」"
        },
        {
          "id": "pm4",
          "text": "医者回头看他，灯火在他眼底摇晃：「所以你要记住。学医不是为了让别人跪着谢你，是为了有一日，谁都不必跪着求命。」"
        },
        {
          "id": "pm5",
          "text": "病童的母亲在泥地里磕头时，医者扶住她：「别跪。孩子要醒来，第一眼该看见娘站着。」"
        },
        {
          "id": "pm6",
          "text": "徒弟在邻家的灯下磨墨，手抖得写不直药方。医者把他的手按稳：「字可以歪，心不能偏。」"
        },
        {
          "id": "pm7",
          "text": "天快亮时，孩子终于退了热。医者坐在廊下，湿透的蓑衣结着寒霜，却只是轻轻笑了一声。"
        },
        {
          "id": "pm8",
          "text": "旧照片里的药签纹路渐渐清晰。那不是昂贵的徽记，而是一盏雨夜里借来的灯，照着后来的人继续往前走。"
        }
      ],
      "choices": [
        {
          "text": "（结束记忆）",
          "effects": {},
          "next": null
        }
      ]
    },
    "clock_memory_dialogue": {
      "speaker": "修钟匠精魂",
      "lines": [
        {
          "id": "clm1",
          "text": "守城兵：「老钟匠，别修了。敌军已经到北坡，今夜没人会怪你。」"
        },
        {
          "id": "clm2",
          "text": "匠人咬着一枚铜钉，手指冻得发紫，却还在校齿轮：「我怪我自己。」"
        },
        {
          "id": "clm3",
          "text": "守城兵：「一口钟，真能守住城吗？」"
        },
        {
          "id": "clm4",
          "text": "匠人抬眼，听见远处巷子里有人抱着孩子奔跑：「钟守不住城。可只要更声还响，城里的人就知道，我们还没放弃。」"
        },
        {
          "id": "clm5",
          "text": "守城兵沉默片刻，把自己的披风披到匠人肩上：「那你修钟，我守门。」"
        },
        {
          "id": "clm6",
          "text": "匠人笑骂：「披风拿走，别冻死在门口。你若倒了，我这钟敲给谁听？」"
        },
        {
          "id": "clm7",
          "text": "子夜将至，第一声更响穿过长街。有人在黑暗里停下脚步，有人重新背起粮袋，有人擦干眼泪继续往城南跑。"
        },
        {
          "id": "clm8",
          "text": "最后一声更落下时，铜齿轮滚进匠人掌心。齿尖刻着旧门牌纹，像一段没有说出口的约定：更声未尽，人心不散。"
        }
      ],
      "choices": [
        {
          "text": "（结束记忆）",
          "effects": {},
          "next": null
        }
      ]
    }
  }
}