  "dialogues": {
    "ring_memory_dialogue": {
      "speaker": "旁白",
      "lines": [
        {
          "id": "rm1",
          "text": "城门外的火把被夜风压低，年轻军士把一枚戒指系在红绳上，交给即将出城报信的同伴。"
        },
        {
          "id": "rm2",
          "text": "他说：若我没能回来，就把它送回家中。不是报丧，是告诉他们，我守到最后一刻。"
        },
        {
          "id": "rm3",
          "text": "同伴跪在泥地里应下。城上鼓声一声接一声，像把人的胆怯一点点敲碎。"
        },
        {
          "id": "rm4",
          "text": "记忆尽头，戒指内侧浮出一道铜纹。它不像装饰，更像某个家族曾经立下的守诺印记。"
        }
      ],
      "choices": [
        {
          "text": "（结束记忆）",
          "effects": {},
          "next": null
        }
      ]
    },
    "elder_memory_dialogue": {
      "speaker": "旁白",
      "lines": [
        {
          "id": "em1",
          "text": "清晨的乡塾还没有点灯，先生已经把孩子们的课本摊开，逐页抚平被雨泡皱的纸。"
        },
        {
          "id": "em2",
          "text": "有人劝他逃难，他只说：书可以晚些读，但不能没人替孩子们记得回来的路。"
        },
        {
          "id": "em3",
          "text": "门外兵荒马乱，屋里却响起参差的晨读声。那声音很轻，却把一间小屋撑得很稳。"
        },
        {
          "id": "em4",
          "text": "先生把一张油印纸条夹进教案，纸角画着一枚旧门牌，像在托付后来的人继续点灯。"
        }
      ],
      "choices": [
        {
          "text": "（结束记忆）",
          "effects": {},
          "next": null
        }
      ]
    },
    "cat_memory_dialogue": {
      "speaker": "旁白",
      "lines": [
        {
          "id": "cm1",
          "text": "旧巷的屋檐下挂着铜铃，风一吹就响。一个孩子抱着空竹篮，沿着墙根找一只不肯回家的猫。"
        },
        {
          "id": "cm2",
          "text": "邻里有人递来半盏热汤，有人帮他敲开柴门。小小的脚印在雨后泥地里断断续续。"
        },
        {
          "id": "cm3",
          "text": "孩子没有放弃，因为他记得猫也曾在他发烧时守在枕边，一整夜没有离开。"
        },
        {
          "id": "cm4",
          "text": "檐铃最后响了一下，像在提醒：被认真寻找的东西，总会记得回家的方向。"
        }
      ],
      "choices": [
        {
          "text": "（结束记忆）",
          "effects": {},
          "next": null
        }
      ]
    },
    "photo_memory_dialogue": {
      "speaker": "旁白",
      "lines": [
        {
          "id": "pm1",
          "text": "雨夜里，药铺的灯被风吹得忽明忽暗。医者披着蓑衣，背起药箱走进泥泞小路。"
        },
        {
          "id": "pm2",
          "text": "徒弟问他：这家人付不起诊金，真的还去吗？医者只答：病不等天晴，人命也不看银两。"
        },
        {
          "id": "pm3",
          "text": "他借着邻家的灯写下药方，把最后一包药留下，自己在廊下坐到天亮。"
        },
        {
          "id": "pm4",
          "text": "照片中的药签纹路渐渐清晰，像一枚被岁月磨淡的纹章，提醒后来的人记住仁心。"
        }
      ],
      "choices": [
        {
          "text": "（结束记忆）",
          "effects": {},
          "next": null
        }
      ]
    },
    "clock_memory_dialogue": {
      "speaker": "旁白",
      "lines": [
        {
          "id": "clm1",
          "text": "更楼上，匠人把铜齿轮装进木制更钟。城中宵禁已起，远处仍有归人的脚步声。"
        },
        {
          "id": "clm2",
          "text": "他答应过守城的人：只要钟还响，城里的人就知道今夜还没有失守。"
        },
        {
          "id": "clm3",
          "text": "子夜将近，匠人的手被冻得发抖，仍一点点校准齿轮，让更声稳稳传过长街。"
        },
        {
          "id": "clm4",
          "text": "最后一声更响后，一枚铜齿轮落入掌心。齿尖刻着门牌纹，像把守诺的时间交给后来的人。"
        }
      ],
      "choices": [
        {
          "text": "（结束记忆）",
          "effects": {},
          "next": null
        }
      ]
    }
  }
}
