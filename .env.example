# 万事屋炼金物语 - 环境变量示例
# 本文件仅包含占位变量，不包含真实密钥
# 复制为 .env 后填入实际值（.env 不应提交到 Git）

# -------------------------------------------------------------------
# CloudBase 配置（前端可见，非敏感）
# -------------------------------------------------------------------
CLOUDBASE_ENV_ID=wanshiwu-game-dev-d7dnulbc30e85d

# -------------------------------------------------------------------
# 云审核模式控制（前端可见，非敏感）
# -------------------------------------------------------------------
# 是否启用云安全 mock 模式（无云环境时设为 true）
SECURITY_CLOUD_MOCK=true
# 是否启用安全日志
SECURITY_LOG_ENABLED=true

# -------------------------------------------------------------------
# 以下变量是"云函数环境变量"，只能在 CloudBase 控制台配置
# 绝对不要写入此 .env 文件或前端代码或提交到公开仓库
# -------------------------------------------------------------------

# 是否启用腾讯云 TMS（云函数环境变量，默认 false）
# TMS_ENABLED=false

# 腾讯云密钥（云函数环境变量，严禁放前端）
# 注意：CloudBase 不允许 TENCENTCLOUD_ 前缀，统一使用 TC_ 前缀
# TC_SECRET_ID=
# TC_SECRET_KEY=
# TC_REGION=ap-shanghai

# TMS 业务类型（可选）
# TMS_BIZ_TYPE=
